<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1EC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Dashboard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#6D4C41"
            android:layout_marginBottom="16dp"/>

        <!-- Only add views here in Java -->
        <LinearLayout
            android:id="@+id/habitContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Buttons at the bottom -->
        <Button
            android:id="@+id/heartWalkButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Heart Walk"
            android:layout_marginTop="24dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8D6E63"
            android:padding="12dp"/>

        <Button
            android:id="@+id/reflectionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="End of Day Reflection"
            android:layout_marginTop="12dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8D6E63"
            android:padding="12dp"/>

        <Button
            android:id="@+id/continueButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continue"
            android:layout_marginTop="12dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8D6E63"
            android:padding="12dp"/>
    </LinearLayout>
</ScrollView>